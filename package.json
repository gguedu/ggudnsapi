{
  "name": "ggudnsapi",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:api": "wrangler dev",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build": "tsc -b frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc -b frontend/tsconfig.json",
    "lint": "oxlint frontend/src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^5.20260710.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
